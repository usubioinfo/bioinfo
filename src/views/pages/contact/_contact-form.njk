<input aria-label="Name Form" name="name" id="formName" type="text" class="form-control kbl-form" placeholder="Full Name">
<input aria-label="Email Form" name="email"  id="formEmail" type="email" class="form-control kbl-form" placeholder="Email">
<input aria-label="Phone Form" name="phone" id="formPhone" class="form-control kbl-form"  placeholder="Phone Number">
<textarea aria-label="Message Form" name="message"  id="formMessage" class="form-control kbl-form" rows="15" placeholder="Say something to us!"></textarea>

<button class="btn kbl-btn-1-solid" id="send">Send Message</button>
